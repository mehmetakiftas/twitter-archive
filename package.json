{
  "name": "twitter-archive",
  "version": "1.0.0",
  "description": "Self-hosted Twitter/X archive system for personal use",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:create": "node src/db/scripts/create-database.js",
    "db:drop": "node src/db/scripts/drop-database.js",
    "db:migrate": "node src/db/migrate.js",
    "db:reset": "node src/db/scripts/reset-database.js",
    "db:seed": "node src/db/scripts/seed-categories.js",
    "db:check": "node src/db/scripts/check-connection.js",
    "db:setup": "node src/db/scripts/setup.js"
  },
  "dependencies": {
    "@fastify/compress": "^7.0.3",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.1",
    "pg": "^8.13.1"
  },
  "keywords": [
    "twitter",
    "archive",
    "personal",
    "fastify",
    "postgresql",
    "vanilla-js",
    "dark-mode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mehmetakiftas/twitter-archive.git"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
